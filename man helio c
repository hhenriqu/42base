//// ESTUDOS DE PONTEIROS & ARRAYS (VETORES E MATRIZES)
//*arrays sao definidos em dois tipos, vetores quando tiver apenas uma dimensao
//e metriz quando houver mais de uma;

char x; // variavel simples, aloca dados confrome atribuidos.

char *x; // Famoso ponteiro, o '*' (asterisco || estrelinha) significa que estamos
		// APONTANDO para a primeira posicao de uma array;

char x = "helio" // [h][e][l][i][o]  <- ou seja o ponteiro aponta para 'h' ou &x = x[0]
				//   0  1  2  3  4      primeira posicao de x
				
