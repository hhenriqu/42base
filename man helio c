//EXEMPLO - EXERCICIO INTERNET - VIDEO//

int *pvet[2]; // Variavel tipo INT - Ponteiro PVET [MATRIZ]
int x = 10, y[2] = {20,30}; // declaracao de x e y no caso y tem duas casas
pvet[0] = &x; // primeira posicao do pvet armazena um endereco
pvet[1] = y // segunda posicao de pvet tambem armazera um endereco, como y `e
			// array nao precisa de &, naturalmente ja aponta pra primeira posicao

printf ("pvet[0] %p\n",pvet[0]);//chama &x
printf ("pvet[1] %p\n",pvet[1]);//chama &y[0]
printf ("*pvet[0] %p\n",*pvet[0]);//chama conteudo de &x no caso x
printf ("pvet[1] %p\n",pvet[1][1]);//chama conteudo de &y na posicao [1] no caso y[1]

